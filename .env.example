# ═══════════════════════════════════════════════════════════════════
#  Provider selection
# ═══════════════════════════════════════════════════════════════════
# Change LLM_PROVIDER to switch between models without touching
# the other providers' keys.
LLM_PROVIDER=deepseek

# ═══════════════════════════════════════════════════════════════════
#  DeepSeek
# ═══════════════════════════════════════════════════════════════════
DEEPSEEK_API_KEY=your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# ═══════════════════════════════════════════════════════════════════
#  Qwen (通义千问)
# ═══════════════════════════════════════════════════════════════════
# QWEN_API_KEY=your-api-key-here
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen3-7b-plus

# ═══════════════════════════════════════════════════════════════════
#  OpenAI
# ═══════════════════════════════════════════════════════════════════
# OPENAI_API_KEY=your-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ═══════════════════════════════════════════════════════════════════
#  Shared LLM params (apply to all providers)
# ═══════════════════════════════════════════════════════════════════
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096

# ── Agent Behaviour ───────────────────────────────────────────────
AGENT_VERBOSE=true
AGENT_MAX_ITERATIONS=10
AGENT_EARLY_STOPPING=generate

# ── Memory ────────────────────────────────────────────────────────
MEMORY_SESSION_KEY=default

LLM_STREAMING=true

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
